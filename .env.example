# ── Database ──────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/registro_jornada?schema=public"

# ── NextAuth ──────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_IN_PRODUCTION"
NEXTAUTH_URL="http://localhost:3000"

# ── Email (Magic Link) ────────────────────────────────────
# SMTP config for passwordless magic-link auth
EMAIL_SERVER_HOST="smtp.example.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="noreply@empresa.es"
EMAIL_SERVER_PASSWORD="your_smtp_password"
EMAIL_FROM="Registro de Jornada <noreply@empresa.es>"

# ── Encryption (NIF storage) ──────────────────────────────
# AES-256 key for NIF field encryption (RGPD compliance)
# Generate: openssl rand -hex 32
ENCRYPTION_KEY="CHANGE_ME_32_BYTE_HEX_KEY_HERE_000"

# ── App ───────────────────────────────────────────────────
NODE_ENV="development"
